# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
FRONTEND_PORT=3000
# Your public domain (used by nginx in production, e.g. myapp.com)
APP_DOMAIN=localhost

# ─────────────────────────────────────────
# PostgreSQL Database
# ─────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=appdb

# ─────────────────────────────────────────
# JWT Secrets — CHANGE THESE IN PRODUCTION
# Generate with: openssl rand -hex 32
# ─────────────────────────────────────────
JWT_ACCESS_SECRET=change_this_to_a_random_64_char_string_in_production
JWT_REFRESH_SECRET=change_this_to_another_random_64_char_string_in_prod
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ─────────────────────────────────────────
# CORS — set to your frontend URL
# ─────────────────────────────────────────
CORS_ALLOWED_ORIGIN=http://localhost:3000

# ─────────────────────────────────────────
# Email Verification
# Set to true or 1 to require users to verify their email before accessing
# protected routes. When false, accounts are immediately active after register.
# ─────────────────────────────────────────
EMAIL_VERIFICATION_ENABLED=false
